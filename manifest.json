{
  "display_information": {
    "name": "Block Kitchen",
    "description": "Compose Slack messages with a visual block kitchen."
  },
  "features": {
    "bot_user": {
      "display_name": "Block Kitchen",
      "always_online": false
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://YOUR_WORKER_URL/slack/oauth_redirect",
      "https://YOUR_WORKER_URL/slack/user-oauth-redirect"
    ],
    "scopes": {
      "bot": [
        "chat:write",
        "channels:read",
        "groups:read",
        "im:write"
      ],
      "user": [
        "chat:write",
        "im:write"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://YOUR_WORKER_URL/slack/events"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
